<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ReciteRecipe</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Quill CSS for rich text -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🍽️ ReciteRecipe</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbars">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbars">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/recipe/create">Create Recipe</a>
                        </li>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" href="/admin">Admin Panel</a>
                            </li>
                        <% } %>
                    <% } %>
                </ul>
                <form class="d-flex me-3" method="GET" action="/">
                    <input class="form-control me-2" type="search" name="q" placeholder="Search recipes by title..." value="<%= typeof query !== 'undefined' ? query : '' %>" required>
                    <button class="btn btn-outline-success" type="submit">Search</button>
                </form>
                <ul class="navbar-nav mb-2 mb-lg-0">
                    <% if (user) { %>
                        <li class="nav-item">
                            <span class="nav-link text-white">Hello, <strong><%= user.username %></strong></span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light ms-2" href="/logout">Logout</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary ms-2" href="/register">Register</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container pb-5">
