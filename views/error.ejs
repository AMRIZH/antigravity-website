<%- include('partials/header') %>
    <div class="row mt-5">
        <div class="col-lg-8 mx-auto">
            <div class="alert alert-danger shadow-lg border-0 rounded-4 p-5">
                <div class="text-center mb-4">
                    <h1 class="display-3 fw-bold text-danger">⚠️</h1>
                    <h2 class="alert-heading fw-bold">Oops! Something went wrong</h2>
                    <p class=" lead text-dark">
                        <%= message %>
                    </p>
                </div>

                <hr class="border-danger opacity-25 my-4">

                <div class="card bg-dark text-light border-0 shadow-sm rounded-3">
                    <div class="card-header bg-black text-warning font-monospace small">
                        <i class="bi bi-bug"></i> Developer Stack Trace
                    </div>
                    <div class="card-body p-3" style="overflow-x: auto; max-height: 400px;">
                        <pre class="mb-0 font-monospace text-wrap" style="font-size: 0.85rem;"><%= error %></pre>
                    </div>
                </div>

                <div class="mt-4 text-center">
                    <a href="/" class="btn btn-danger btn-lg rounded-pill fw-bold px-5 shadow-sm">🏠 Return to
                        Homepage</a>
                </div>
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>