<%- include('partials/header') %>
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h2 class="mb-4 text-primary fw-bold">✨ Create New Recipe</h2>
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">
                    <form action="/recipe/create" method="POST" enctype="multipart/form-data" id="recipeForm">
                        <div class="mb-4">
                            <label for="title" class="form-label fw-bold">Recipe Title</label>
                            <input type="text" class="form-control form-control-lg rounded-pill" id="title" name="title"
                                required placeholder="e.g. Delicious Pasta Carbonara">
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Description (Ingredients & Instructions)</label>
                            <!-- Quill Editor Container -->
                            <div id="editor-container"
                                style="height: 350px; background-color: #f8f9fa; border: 1px solid #ced4da; border-radius: 0.5rem;">
                            </div>
                            <input type="hidden" name="description" id="description">
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Feature Image</label>
                            <div class="row g-2 align-items-center">
                                <div class="col-md-6">
                                    <label class="text-secondary small mb-1">Upload File</label>
                                    <input type="file" class="form-control" name="imageFile" accept="image/*">
                                </div>
                                <div class="col-md-1 text-center text-muted fw-bold">OR</div>
                                <div class="col-md-5">
                                    <label class="text-secondary small mb-1">Paste Image URL</label>
                                    <input type="url" class="form-control" name="imageUrl" placeholder="https://...">
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">🚀 Post
                            Recipe</button>
                        <a href="/" class="btn btn-outline-secondary btn-lg rounded-pill px-4 ms-2 fw-bold">❌ Cancel</a>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Write your delicious recipe here...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    [{ 'script': 'sub' }, { 'script': 'super' }],
                    [{ 'indent': '-1' }, { 'indent': '+1' }],
                    [{ 'direction': 'rtl' }],
                    [{ 'size': ['small', false, 'large', 'huge'] }],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'font': [] }],
                    [{ 'align': [] }],
                    ['link'],
                    ['clean']
                ]
            }
        });

        document.getElementById('recipeForm').onsubmit = function () {
            var description = document.querySelector('input[name=description]');
            description.value = quill.root.innerHTML;
            if (quill.getText().trim().length === 0) {
                alert('Description cannot be empty!');
                return false;
            }
        };
    </script>
    <%- include('partials/footer') %>